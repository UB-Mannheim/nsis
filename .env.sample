# Inference Provider API Configuration
INFERENCE_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
INFERENCE_PROVIDER_API_KEY=<your-api-key-here>

# Safe hosts
SAFE_HOSTS= # Comma-separated hostnames where auto blocking is disabled, e.g. <dev-server>
SAFE_IP_RANGES= # Comma-separated CIDR ranges of safe IPs that should never be auto-blocked, e.g. 192.168.0.0/24,13.13.13.13/0

# IP Blocking Configuration (comma-separated list of IPs and/or CIDR ranges)
BLOCKED_IPS= # e.g. 192.168.1.1,10.0.0.5
BLOCKED_IP_RANGES= # e.g. 192.168.1.0/24,10.10.0.0/16

# Auto IP Blocking Configuration (for bot detection)
AUTO_BLOCK_ENABLED=true
AUTO_BLOCK_THRESHOLD=10.0
AUTO_BLOCK_WINDOW_MINUTES=60
AUTO_BLOCK_RATE_VIOLATIONS_WEIGHT=5
AUTO_BLOCK_ERRORS_WEIGHT=3
AUTO_BLOCK_REQUEST_VOLUME_WEIGHT=500

# Server Configuration
HOST=<ip>
PORT=<port>
DOMAIN=<public-domain> # e.g. kompass.vufind.de
